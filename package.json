{
  "name": "docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0 || true",
    "test": "node scripts/parallel-test-runner.js",
    "test:unit": "jest --testMatch=\"**/__tests__/unit/**/*\"",
    "test:integration": "jest --testMatch=\"**/__tests__/integration/**/*\"",
    "test:e2e": "jest --testMatch=\"**/__tests__/e2e/**/*\" --runInBand",
    "test:performance": "jest --testMatch=\"**/__tests__/performance/**/*\" --runInBand --testTimeout=30000",
    "test:optimized": "bash scripts/run-tests.sh",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:setup": "node scripts/setup-test-environment.js",
    "pretest": "npm run test:setup"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^5.1.1",
    "chart.js": "^4.4.3",
    "next": "^14.1.1",
    "next-auth": "^4.24.7",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@next/eslint-plugin-next": "^14.1.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/eslint": "^8.56.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.19",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit-reporter": "^1.1.0",
    "jest-watch-typeahead": "^2.2.2",
    "postcss": "^8.4.38",
    "prisma": "^5.16.1",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest-junit": {
    "outputDirectory": "test-reports",
    "outputName": "junit.xml",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › "
  }
}